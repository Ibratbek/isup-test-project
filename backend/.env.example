# Server
PORT=3000
NODE_ENV=development

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Database
DB_PATH=./data/hikvision.db

# ISUP Bridge
ISUP_BRIDGE_PORT=7660

# File storage
UPLOAD_DIR=./data/uploads
FACE_IMAGES_DIR=./data/faces

# Logging
LOG_LEVEL=info

# JWT secret (ishlab chiqarishda kuchli sir so'z ishlating)
JWT_SECRET=change-me-in-production-use-32-chars-min

# API key autentifikatsiya (JWT o'rniga)
API_KEY=your-api-key-here

# Auth method: jwt | apikey | none
AUTH_METHOD=apikey

# Redis command response timeout (ms)
COMMAND_TIMEOUT_MS=10000
